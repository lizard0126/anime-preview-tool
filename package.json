{
  "name": "anime-preview-tool",
  "version": "4.0.0",
  "type": "module",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder"
  },
  "build": {
    "appId": "com.lizard.anime-preview-tool",
    "productName": "Anime Preview Tool",
    "directories": {
      "output": "dist"
    },
    "asarUnpack": [
      "assets/**/*"
    ],
    "files": [
      "main.js",
      "preload.js",
      "renderer/**/*",
      "src/**/*"
    ],
    "win": {
      "target": "portable",
      "icon": "src/icon.ico"
    }
  },
  "devDependencies": {
    "electron": "^41.0.2",
    "electron-builder": "^26.8.1"
  },
  "dependencies": {
    "cheerio": "^1.2.0",
    "ejs": "^5.0.1",
    "fs-extra": "^11.3.4",
    "mammoth": "^1.12.0",
    "puppeteer": "^24.39.1"
  }
}