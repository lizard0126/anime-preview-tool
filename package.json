{
  "name": "jcieo-anime-preview",
  "version": "1.0.0",
  "description": "节操新番导视 - 天央动漫社节操部新番导视图片生成工具",
  "author": "蜥蜴",
  "type": "module",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder"
  },
  "build": {
    "appId": "com.lizard.anime-preview-tool",
    "productName": "节操部新番导视",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "renderer/**/*",
      "src/**/*",
      "!src/fonts"
    ],
    "extraResources": [
      {
        "from": "src/fonts",
        "to": "fonts",
        "filter": ["**/*"]
      },
      {
        "from": "README.md",
        "to": "README.md"
      }
    ],
    "win": {
      "target": "portable",
      "icon": "src/icon.ico"
    }
  },
  "devDependencies": {
    "electron": "^41.0.2",
    "electron-builder": "^26.8.1"
  },
  "dependencies": {
    "axios": "^1.18.1",
    "cheerio": "^1.0.0",
    "ejs": "^5.0.1",
    "fs-extra": "^11.3.4",
    "puppeteer": "^24.39.1"
  }
}
